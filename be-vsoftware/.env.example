# ─────────────────────────────────────────────────────────────────────────────
# Copy file này thành .env và sửa giá trị theo môi trường (local vs prod).
# docker-compose.yml đọc file .env này tự động.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=news_db
DB_PORT_HOST=5433              # Port Postgres mở ra host (container vẫn dùng 5432)

# ── BE / FE ports trên host ──────────────────────────────────────────────────
BE_PORT=3001
FE_PORT=3000

# ── BE: JWT secrets (PROD: PHẢI ĐỔI sang chuỗi ngẫu nhiên dài) ──────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_REFRESH_EXPIRES_IN=30d

# ── BE: URL công khai và CORS ───────────────────────────────────────────────
# LOCAL:  PUBLIC_URL=http://localhost:3001
# PROD:   PUBLIC_URL=https://api.viai.vn
PUBLIC_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000

# ── BE: SMTP (gửi mail liên hệ) ─────────────────────────────────────────────
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=ViAI
CONTACT_RECEIVE_EMAIL=

# ── FE: build-time NEXT_PUBLIC_* ────────────────────────────────────────────
# Quan trọng: thay đổi giá trị này → phải REBUILD image FE
# LOCAL:  http://localhost:3001
# PROD:   https://api.viai.vn
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=ViAI

# ── Seed control ────────────────────────────────────────────────────────────
# FORCE_RESEED=1 → khi container start sẽ TRUNCATE toàn bộ DB rồi restore từ snapshot.json
# deploy.sh tự bật biến này khi phát hiện snapshot.json đã thay đổi
FORCE_RESEED=0
